rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }

    // Validation Blueprint for User
    function isValidUser(data) {
      return data.keys().hasOnly(['userName', 'dailyLimitMinutes', 'alarms', 'createdAt', 'updatedAt']) &&
             data.userName is string && data.userName.size() > 0 && data.userName.size() <= 64 &&
             (data.get('dailyLimitMinutes', 0) is number) &&
             (data.get('alarms', {}).keys().hasOnly(['cambioMateria', 'finSesion']) || data.get('alarms', null) == null) &&
             data.createdAt == request.time && data.updatedAt == request.time;
    }
    
    function isValidUserUpdate(data) {
       return data.keys().hasOnly(['userName', 'dailyLimitMinutes', 'alarms', 'updatedAt']) &&
             (data.get('userName', 'ok') is string) &&
             (data.get('dailyLimitMinutes', 0) is number) &&
             (data.get('alarms', {}).keys().hasOnly(['cambioMateria', 'finSesion']) || data.get('alarms', null) == null) &&
             data.updatedAt == request.time;
    }

    // Validation Blueprint for Subject
    function isValidSubject(data) {
      return data.keys().hasOnly(['userId', 'name', 'subtitle', 'color', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 128 &&
             (data.get('subtitle', 'ok') is string) && (data.get('subtitle', '').size() <= 256) &&
             data.color is string && data.color.size() <= 32 &&
             data.createdAt == request.time && data.updatedAt == request.time;
    }

    function isValidSubjectUpdate(data) {
      return data.keys().hasOnly(['name', 'subtitle', 'color', 'updatedAt']) &&
             (data.get('name', 'ok') is string) && (data.get('name', '').size() <= 128) &&
             (data.get('subtitle', 'ok') is string) && (data.get('subtitle', '').size() <= 256) &&
             (data.get('color', 'ok') is string) && (data.get('color', '').size() <= 32) &&
             data.updatedAt == request.time;
    }

    // Validation Blueprint for Task
    function isValidTask(data) {
      return data.keys().hasOnly(['userId', 'title', 'date', 'subject', 'estimatedMinutes', 'workload', 'isCompleted', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 128 &&
             data.date is string && data.date.size() <= 32 &&
             data.subject is string && data.subject.size() <= 128 &&
             data.estimatedMinutes is number &&
             data.workload in ['Alta', 'Media', 'Óptima'] &&
             data.isCompleted is bool &&
             data.createdAt == request.time && data.updatedAt == request.time;
    }

    function isValidTaskUpdate(data) {
       return data.keys().hasOnly(['title', 'date', 'subject', 'estimatedMinutes', 'workload', 'isCompleted', 'updatedAt']) &&
              (data.get('title', 'ok') is string) && (data.get('title', 'ok').size() <= 128) &&
              (data.get('date', 'ok') is string) && (data.get('date', 'ok').size() <= 32) &&
              (data.get('subject', 'ok') is string) && (data.get('subject', 'ok').size() <= 128) &&
              (data.get('estimatedMinutes', 0) is number) &&
              (data.get('workload', 'Media') in ['Alta', 'Media', 'Óptima']) &&
              (data.get('isCompleted', true) is bool) &&
              data.updatedAt == request.time;
    }

    // Validation Blueprint for CalendarEvent
    function isValidCalendarEvent(data) {
      return data.keys().hasOnly(['userId', 'title', 'date', 'type', 'time', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 128 &&
             data.date is number &&
             data.type in ['Exámenes', 'Trabajos', 'Deberes'] &&
             data.time is string && data.time.size() <= 16 &&
             data.createdAt == request.time && data.updatedAt == request.time;
    }

    function isValidCalendarEventUpdate(data) {
       return data.keys().hasOnly(['title', 'date', 'type', 'time', 'updatedAt']) &&
              (data.get('title', 'ok') is string) && (data.get('title', 'ok').size() <= 128) &&
              (data.get('date', 0) is number) &&
              (data.get('type', 'Deberes') in ['Exámenes', 'Trabajos', 'Deberes']) &&
              (data.get('time', 'ok') is string) && (data.get('time', 'ok').size() <= 16) &&
              data.updatedAt == request.time;
    }

    // Validation Blueprint for Extracurricular
    function isValidExtracurricular(data) {
      return data.keys().hasOnly(['userId', 'title', 'days', 'time', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 128 &&
             data.days is string && data.days.size() <= 128 &&
             data.time is string && data.time.size() <= 64 &&
             data.createdAt == request.time && data.updatedAt == request.time;
    }

    function isValidExtracurricularUpdate(data) {
       return data.keys().hasOnly(['title', 'days', 'time', 'updatedAt']) &&
              (data.get('title', 'ok') is string) && (data.get('title', 'ok').size() <= 128) &&
              (data.get('days', 'ok') is string) && (data.get('days', 'ok').size() <= 128) &&
              (data.get('time', 'ok') is string) && (data.get('time', 'ok').size() <= 64) &&
              data.updatedAt == request.time;
    }


    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && isValidId(userId) && request.auth.uid == userId && isValidUserUpdate(incoming().diff(existing()).affectedKeys()) &&
                    // Just verifying structure, the helper ensures no forbidden keys are updated
                    // We check that the updated fields are valid types
                    (
                      incoming().diff(existing()).affectedKeys().hasOnly(['userName', 'dailyLimitMinutes', 'alarms', 'updatedAt'])
                    ) &&
                    // Ensure the keys being updated match their respective types
                    (
                       (!('userName' in incoming().diff(existing()).affectedKeys()) || (incoming().userName is string && incoming().userName.size() <= 64)) &&
                       (!('dailyLimitMinutes' in incoming().diff(existing()).affectedKeys()) || incoming().dailyLimitMinutes is number) &&
                       (!('alarms' in incoming().diff(existing()).affectedKeys()) || incoming().alarms.keys().hasOnly(['cambioMateria', 'finSesion'])) &&
                       (!('updatedAt' in incoming().diff(existing()).affectedKeys()) || incoming().updatedAt == request.time)
                    );
    }

    match /subjects/{subjectId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(subjectId) && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(subjectId) && isValidSubject(incoming());
      allow update: if isSignedIn() && isValidId(subjectId) && existing().userId == request.auth.uid &&
                    incoming().userId == existing().userId &&
                    isValidSubjectUpdate(incoming().diff(existing()).affectedKeys()) &&
                    (
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'subtitle', 'color', 'updatedAt'])
                    ) &&
                    (
                       (!('name' in incoming().diff(existing()).affectedKeys()) || (incoming().name is string && incoming().name.size() <= 128)) &&
                       (!('subtitle' in incoming().diff(existing()).affectedKeys()) || (incoming().subtitle is string && incoming().subtitle.size() <= 256)) &&
                       (!('color' in incoming().diff(existing()).affectedKeys()) || (incoming().color is string && incoming().color.size() <= 32)) &&
                       (!('updatedAt' in incoming().diff(existing()).affectedKeys()) || incoming().updatedAt == request.time)
                    );
      allow delete: if isSignedIn() && isValidId(subjectId) && resource.data.userId == request.auth.uid;
    }

    match /tasks/{taskId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(taskId) && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(taskId) && isValidTask(incoming());
      allow update: if isSignedIn() && isValidId(taskId) && existing().userId == request.auth.uid &&
                    incoming().userId == existing().userId &&
                    isValidTaskUpdate(incoming().diff(existing()).affectedKeys()) &&
                    (
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'date', 'subject', 'estimatedMinutes', 'workload', 'isCompleted', 'updatedAt'])
                    ) &&
                    (
                       (!('title' in incoming().diff(existing()).affectedKeys()) || (incoming().title is string && incoming().title.size() <= 128)) &&
                       (!('date' in incoming().diff(existing()).affectedKeys()) || (incoming().date is string && incoming().date.size() <= 32)) &&
                       (!('subject' in incoming().diff(existing()).affectedKeys()) || (incoming().subject is string && incoming().subject.size() <= 128)) &&
                       (!('estimatedMinutes' in incoming().diff(existing()).affectedKeys()) || incoming().estimatedMinutes is number) &&
                       (!('workload' in incoming().diff(existing()).affectedKeys()) || incoming().workload in ['Alta', 'Media', 'Óptima']) &&
                       (!('isCompleted' in incoming().diff(existing()).affectedKeys()) || incoming().isCompleted is bool) &&
                       (!('updatedAt' in incoming().diff(existing()).affectedKeys()) || incoming().updatedAt == request.time)
                    );
      allow delete: if isSignedIn() && isValidId(taskId) && resource.data.userId == request.auth.uid;
    }

    match /calendarEvents/{eventId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(eventId) && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(eventId) && isValidCalendarEvent(incoming());
      allow update: if isSignedIn() && isValidId(eventId) && existing().userId == request.auth.uid &&
                    incoming().userId == existing().userId &&
                    isValidCalendarEventUpdate(incoming().diff(existing()).affectedKeys()) &&
                    (
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'date', 'type', 'time', 'updatedAt'])
                    ) &&
                    (
                       (!('title' in incoming().diff(existing()).affectedKeys()) || (incoming().title is string && incoming().title.size() <= 128)) &&
                       (!('date' in incoming().diff(existing()).affectedKeys()) || incoming().date is number) &&
                       (!('type' in incoming().diff(existing()).affectedKeys()) || incoming().type in ['Exámenes', 'Trabajos', 'Deberes']) &&
                       (!('time' in incoming().diff(existing()).affectedKeys()) || (incoming().time is string && incoming().time.size() <= 16)) &&
                       (!('updatedAt' in incoming().diff(existing()).affectedKeys()) || incoming().updatedAt == request.time)
                    );
      allow delete: if isSignedIn() && isValidId(eventId) && resource.data.userId == request.auth.uid;
    }

    match /extracurriculars/{activityId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(activityId) && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(activityId) && isValidExtracurricular(incoming());
      allow update: if isSignedIn() && isValidId(activityId) && existing().userId == request.auth.uid &&
                    incoming().userId == existing().userId &&
                    isValidExtracurricularUpdate(incoming().diff(existing()).affectedKeys()) &&
                    (
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'days', 'time', 'updatedAt'])
                    ) &&
                    (
                       (!('title' in incoming().diff(existing()).affectedKeys()) || (incoming().title is string && incoming().title.size() <= 128)) &&
                       (!('days' in incoming().diff(existing()).affectedKeys()) || (incoming().days is string && incoming().days.size() <= 128)) &&
                       (!('time' in incoming().diff(existing()).affectedKeys()) || (incoming().time is string && incoming().time.size() <= 64)) &&
                       (!('updatedAt' in incoming().diff(existing()).affectedKeys()) || incoming().updatedAt == request.time)
                    );
      allow delete: if isSignedIn() && isValidId(activityId) && resource.data.userId == request.auth.uid;
    }
  }
}
